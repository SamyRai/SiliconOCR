# Environment configuration for OCR service

# Device configuration (mps for Apple Silicon, cuda for NVIDIA, cpu for CPU)
DEVICE=mps
USE_FP16=true

# OCR configuration
OCR_ENGINE=easyocr
OCR_LANGUAGES=["en", "de"]

# Models
TEXT_EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
MULTIMODAL_MODEL=openai/clip-vit-base-patch32
TRANSLATION_MODEL=Helsinki-NLP/opus-mt-de-en

# Performance tuning
BATCH_SIZE=64
TRANSLATION_BATCH_SIZE=32
MAX_WORKERS=4
ENABLE_TORCH_COMPILE=true

# Image processing
MAX_IMAGE_PIXELS=178956970
PDF_DPI=200

# Paths
CACHE_DIR=~/.cache/ocr-service
MODEL_CACHE_DIR=~/.cache/huggingface

# API (if running as service)
API_HOST=0.0.0.0
API_PORT=8000
